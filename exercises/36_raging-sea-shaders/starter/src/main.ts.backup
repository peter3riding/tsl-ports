  /**
   * Camera
   */
  const camera = new THREE.PerspectiveCamera(
    75,
    sizes.width / sizes.height,
    0.1,
    100,
  );
  camera.position.set(0, 5, 0);
  scene.add(camera);

  /**
   * Controls
   */
  const controls = new OrbitControls(camera, canvas);
  controls.enableDamping = true;
  controls.target.set(0, 0, 0);

  /**
   * Renderer + Post-processing
   */
  console.log("Creating WebGLRenderer for testing...");
  const renderer = new THREE.WebGLRenderer({
    canvas: canvas,
    antialias: true,
  });
  console.log("WebGLRenderer created:", renderer);

  renderer.setSize(sizes.width, sizes.height);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  console.log("Renderer size set:", sizes.width, sizes.height);

  // Simple direct rendering without post-processing
  const tick = () => {
    timer.update();
    uTime.value = timer.getElapsed();

    controls.update();

    console.log("Rendering frame...");
    renderer.render(scene, camera);
  };

  console.log("Starting animation loop...");
  renderer.setAnimationLoop(tick);
})();
